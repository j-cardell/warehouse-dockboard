# Warehouse Dock Board Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# REQUIRED: Security Settings
# These MUST be changed from defaults before running in production
# ============================================================================

# Bootstrap admin credentials
# - Used for first login to create the admin user in users.json
# - Must be at least 8 characters
# - Password can ONLY be changed by the AUTH_PASS variable! NOT via the UI.
AUTH_USER=dockadmin-change-to-something-you-like
AUTH_PASS=change-this-to-your-secure-password

# JWT signing secret for authentication tokens
# - Generate with: openssl rand -hex 32
# - Must be changed from default
# - Keep this secret secure and never share it
JWT_SECRET=your-jwt-secret-here

# ============================================================================
# Optional: Server Configuration
# ============================================================================

# Server port (default: 3456 for Docker, 3000 for local)
PORT=3456

# JWT token expiration time (default: 24h)
# Format: number + unit (m=minutes, h=hours, d=days)
JWT_EXPIRES_IN=24h

# ============================================================================
# Authentication
# ============================================================================
# Users, once created in the UI are stored in data/facilities/[facility]/users.json
# First login with AUTH_USER/AUTH_PASS automatically creates admin account globally in data/users.json
# Subsequent logins validate against users.json
# Changing AUTH_PASS variable will rehash and replace the bootsrap admin account password in data/users.json
# Use the UI or API to manage additional users