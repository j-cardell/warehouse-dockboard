# Warehouse Dock Board Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# REQUIRED: Security Settings
# These MUST be changed from defaults before running in production
# ============================================================================

# Bootstrap admin credentials
# - Used ONLY for first login to create the admin user in users.json
# - After first login, users.json is the source of truth
# - Must be at least 8 characters
AUTH_USER=dockadmin
AUTH_PASS=change-this-to-secure-password

# JWT signing secret for authentication tokens
# - Generate with: openssl rand -hex 32
# - Must be changed from default
# - Keep this secret secure and never share it
JWT_SECRET=your-jwt-secret-here

# ============================================================================
# Optional: Server Configuration
# ============================================================================

# Server port (default: 3456 for Docker, 3000 for local)
PORT=3456

# JWT token expiration time (default: 24h)
# Format: number + unit (m=minutes, h=hours, d=days)
JWT_EXPIRES_IN=24h

# Node environment (production | development)
# Set to production for production deployments
NODE_ENV=production

# ============================================================================
# Authentication
# ============================================================================
# Users are stored in data/users.json (created on first login)
# First login with AUTH_USER/AUTH_PASS automatically creates admin account
# Subsequent logins validate against users.json
# Use the UI or API to manage additional users
